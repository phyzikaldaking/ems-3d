# URL of the deployed epic-music-space web app (used to fetch live studio data)
EMS_API_URL=https://your-ems-deployment.vercel.app

# Stripe secret key (for marketplace checkout in the 3D city)
STRIPE_SECRET_KEY=sk_live_...

# Public URL of this app (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://your-ems-3d-deployment.vercel.app

# Optional launch flag for production observability and gating
NEXT_PUBLIC_LAUNCH_MODE=true

# PostHog (optional — analytics for 3D navigation events)
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com
