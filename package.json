{
  "name": "ems-3d",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env -u __NEXT_PRIVATE_STANDALONE_CONFIG next dev",
    "build": "env -u __NEXT_PRIVATE_STANDALONE_CONFIG next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:smoke": "playwright test",
    "check:env": "node scripts/check-env.mjs",
    "check:env:strict": "node scripts/check-env.mjs --strict",
    "prelaunch": "npm run lint && npm run typecheck && npm run build && npm run test:smoke"
  },
  "dependencies": {
    "@babylonjs/core": "^7.34.0",
    "@babylonjs/gui": "^7.34.0",
    "@babylonjs/loaders": "^7.34.0",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^17.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.1",
    "typescript": "5.9.3"
  }
}
